PORT=3002
PUBLIC_URL=https://invernadero-backend-9s48.onrender.com

# Local por defecto: MySQL
DB_CLIENT=mysql
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=invernadero.db

# Base secundaria para sincronizar ventas/stock.
# DBeaver es solo el cliente: aqui van los datos reales de esa conexion.
# SYNC_DB_CLIENT=postgres
# SYNC_DB_HOST=localhost
# SYNC_DB_PORT=5432
# SYNC_DB_USER=postgres
# SYNC_DB_PASSWORD=
# SYNC_DB_NAME=invernadero
# SYNC_DB_SSL=false

# En Render/PostgreSQL puedes usar esto en lugar de DB_HOST/DB_USER/etc:
# DB_CLIENT=postgres
# DB_DIALECT=postgres
# DATABASE_URL=postgres://usuario:password@host:5432/base
# DB_SSL=true

# Correo para enviar tickets.
# Para Gmail normalmente se usa una "App password", no tu contrasena normal.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASSWORD=tu_app_password
# SMTP_FROM="Vivero La Palma <tu_correo@gmail.com>"
